{
  "log_level": "INFO",
  "output_path": "reports/packguard-report.json",
  "offline_mode": false,
  "max_file_bytes": 300000,
  "scanners": [
    "threat_feed",
    "typosquat",
    "behavior",
    "static"
  ],
  "fail_on": "malicious",
  "risk_thresholds": {
    "clean": 0,
    "suspicious": 35,
    "malicious": 75
  },
  "typosquat_distance": 1,
  "trusted_scopes": [
    "@types",
    "@angular",
    "@aws-sdk"
  ],
  "private_namespaces": [],
  "popular_packages_path": "data/intel/popular_packages.txt",
  "malicious_feed_path": "data/intel/malicious_packages.json",
  "use_ai": false,
  "ai_provider": "ollama",
  "ai_timeout_seconds": 20,
  "ollama_host": "http://localhost:11434",
  "ollama_model": "llama3.2",
  "openai_base_url": "https://api.openai.com/v1",
  "openai_api_key": "",
  "openai_model": "gpt-5-mini",
  "anthropic_base_url": "https://api.anthropic.com/v1",
  "anthropic_api_key": "",
  "anthropic_model": "claude-sonnet-4-20250514",
  "gemini_base_url": "https://generativelanguage.googleapis.com/v1beta",
  "gemini_api_key": "",
  "gemini_model": "gemini-2.5-flash",
  "groq_base_url": "https://api.groq.com/openai/v1",
  "groq_api_key": "",
  "groq_model": "openai/gpt-oss-20b",
  "openrouter_base_url": "https://openrouter.ai/api/v1",
  "openrouter_api_key": "",
  "openrouter_model": "openai/gpt-5-mini",
  "xai_base_url": "https://api.x.ai/v1",
  "xai_api_key": "",
  "xai_model": "grok-4.20-reasoning"
}
